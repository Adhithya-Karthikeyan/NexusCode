{
  "name": "@nexuscode/cache",
  "version": "0.1.0",
  "description": "NexusCode caching subsystem (system-spec §17) — unified Cache abstraction, memory/disk backends, typed prompt/response/embedding/file caches, prompt prefix-cache helpers, cache-affinity routing, and savings accounting.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@nexuscode/shared": "*"
  },
  "devDependencies": {
    "@nexuscode/context": "*"
  }
}
