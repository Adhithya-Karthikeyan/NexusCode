{
  "name": "@nexuscode/rag",
  "version": "0.1.0",
  "description": "NexusCode RAG subsystem — embeddings, chunking, vector store, hybrid search, citations (system-spec §16).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@nexuscode/config": "*",
    "@nexuscode/context": "*",
    "@nexuscode/provider-ollama": "*",
    "@nexuscode/shared": "*"
  }
}
