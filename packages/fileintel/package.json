{
  "name": "@nexuscode/fileintel",
  "version": "0.1.0",
  "description": "NexusCode file intelligence — language detection, ignore-aware tree walking, a Parser seam (heuristic + web-tree-sitter), symbol/dependency/xref indexing, and an aider-style PageRank repo map.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@nexuscode/shared": "*",
    "@nexuscode/tools": "*",
    "@nexuscode/context": "*"
  }
}
