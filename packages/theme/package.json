{
  "name": "@nexuscode/theme",
  "version": "0.1.0",
  "description": "NexusCode theme engine — pure token data + resolver for the 16 signature palettes. No ink, no runtime deps beyond shared.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@nexuscode/shared": "*",
    "zod": "^3.24.1"
  }
}
