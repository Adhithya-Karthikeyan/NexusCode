{
  "name": "@nexuscode/tools-ai",
  "version": "0.1.0",
  "description": "NexusCode AI tool group — vision, OCR, image generation, and speech (TTS/STT) as Tool-contract tools that route through an injected provider or optional-lazy client libraries.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@nexuscode/core": "*",
    "@nexuscode/shared": "*",
    "@nexuscode/tools": "*"
  }
}
