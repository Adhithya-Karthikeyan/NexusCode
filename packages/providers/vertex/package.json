{
  "name": "@nexuscode/provider-vertex",
  "version": "0.1.0",
  "description": "NexusCode Google Vertex AI provider — native @google/genai (vertex mode) adapter.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@nexuscode/core": "*",
    "@nexuscode/provider-gemini": "*",
    "@nexuscode/shared": "*"
  }
}
