{
  "name": "@nexuscode/provider-codex",
  "version": "0.1.0",
  "description": "NexusCode Codex provider — drives `codex exec --json` as a subprocess and normalizes its JSON events into StreamChunk.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@nexuscode/core": "*",
    "@nexuscode/shared": "*",
    "@nexuscode/provider-subprocess": "*"
  }
}
